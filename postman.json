          "query": [
            { "key": "companyId", "value": "2" }
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Green Tea\",\n  \"parentGroupId\": 9,\n  \"color\": \"#00FF00\",\n  \"rank\": 1\n}"
        }
      }
    },
    {
      "name": "Update Product Group (Move 10 under 11)",
      "request": {
