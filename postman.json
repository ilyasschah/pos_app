          "query": [
            { "key": "companyId", "value": "2" }
          ]
        }
      }
    },
    {
      "name": "Get Product Group By Id (13)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/ProductGroups/GetById?id=13&companyId=2",
          "host": ["{{baseUrl}}"],
          "path": ["api", "ProductGroups", "GetById"],
          "query": [
            { "key": "id", "value": "13" },
            { "key": "companyId", "value": "2" }
          ]
        }
      }
    },
    {
