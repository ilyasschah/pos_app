{
  "info": {
    "name": "POS - Currencies Controller",
    "_postman_id": "c1d2e3f4-a5b6-7c8d-9e0f-currencies-controller",
    "description": "Static Currencies API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7002",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Get All Currencies",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/Currencies/GetAll",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Currencies",
            "GetAll"
          ]
        }
      }
    },
    {
      "name": "Get Currency By Id (1 - USD)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/Currencies/GetById?id=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Currencies",
            "GetById"
          ],
          "query": [
            {
              "key": "id",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "Get Currency By Name (Euro)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/Currencies/GetByName?name=Euro",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Currencies",
            "GetByName"
          ],
          "query": [
            {
              "key": "name",
              "value": "Euro"
            }
          ]
        }
      }
    },
    {
      "name": "Add Currency (New Zealand Dollar)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"New Zealand Dollar\",\n  \"code\": \"NZD\",\n  \"countryId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Currencies/Add?companyId=2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Currencies",
            "Add"
          ],
          "query": [
            {
              "key": "companyId",
              "value": "2"
            }
          ]
        }
      }
    },
    {
      "name": "Update Currency (ID 11)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"New Zealand Dollar Updated\",\n  \"code\": \"NZD\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Currencies/Update?id=11",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Currencies",
            "Update"
          ],
          "query": [
            {
              "key": "id",
              "value": "11"
            }
          ]
        }
      }
    },
    {
      "name": "Delete Currency (ID 11)",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/Currencies/Delete?id=11",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Currencies",
            "Delete"
          ],
          "query": [
            {
              "key": "id",
              "value": "11"
            }
          ]
        }
      }
    }
  ]
}