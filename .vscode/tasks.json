{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter Web Dev Server",
      "type": "shell",
      "command": "flutter",
      "args": [
        "run",
        "-d",
        "web-server",
        "--web-port",
        "8080",
        "--web-hostname",
        "localhost"
      ],
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Launching",
          "endsPattern": "To hot restart"
        }
      }
    }
  ]
}